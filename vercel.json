 {
  "version": 2,
  "builds": [
    {
      "src": "artifacts/api-server/build.mjs",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "artifacts/api-server/build.mjs"
    }
  ],
  "buildCommand": "cd artifacts/api-server && npm run build",
  "outputDirectory": "artifacts/api-server/.vercel/output"
 }
